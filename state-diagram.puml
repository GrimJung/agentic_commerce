@startuml H-AI 여행 예약 챗봇 - 상태 다이어그램
!theme plain
skinparam backgroundColor #FFFFFF
skinparam defaultFontSize 11
skinparam state {
  BackgroundColor<<package>> #E3F2FD
  BackgroundColor<<fit>> #F3E5F5
  BackgroundColor<<booking>> #FFF3E0
  BackgroundColor<<payment>> #E8F5E9
}

title H-AI 여행 예약 챗봇 - 상태 흐름 (step 기준)

[*] --> main : 앱 실행

state main {
  [*] --> MainPage
  MainPage : 랜딩 화면
  MainPage : 칩 메뉴 (퀴즈쇼, 오늘의 운세,\n상품 추천받고 결제하기 등)
}

main --> initial : [상품 추천받고 결제하기] 클릭

state initial {
  [*] --> Chat
  Chat : 채팅 화면 + 헤더(H-AI 하이)
  Chat : "상품 추천해줘" 자동 전송
  Chat --> PersonaCheck : 봇 응답
  PersonaCheck : 페르소나 있음 → [추천 검색] / [직접 검색]
  PersonaCheck : 페르소나 없음 → 여행 타입 선택
  PersonaCheck --> TravelTypeChoice : 선택
  TravelTypeChoice : [패키지 상품] or [자유여행]
}

initial --> preference : 여행 타입 선택

state preference {
  [*] --> PrefForm
  PrefForm : 목적지, 테마, 예산, 여행 시기
  PrefForm : **인원**: 패키지(직접)=성인/아동/유아
  PrefForm : FIT·추천검색=성인+아동만 + 아동 나이(만0~17)
  PrefForm : 자유여행 시 검색 모드: 조합/항공만/숙소만
  PrefForm : Smart-Fill (추천 검색 시)
}

preference --> packages : 패키지 선호도 제출\n+ Agent 검색 완료
preference --> fit_packages : FIT 선호도 제출\n+ Agent 검색 완료

state packages <<package>> {
  [*] --> ShowCards
  ShowCards : 추천 패키지 카드 (최대 3개)
  ShowCards : [상품 비교하기] [추천 다시받기]
  ShowCards --> Detail : 카드 클릭
  ShowCards --> Comparison : 비교하기
  ShowCards --> ShowCards : 추천 다시받기
  Detail : PackageDetail 바텀시트
  Comparison : PackageComparison 바텀시트
  Detail --> ShowCards : 닫기
  Comparison --> Detail : 상품 선택
}

state fit_packages <<fit>> {
  [*] --> ShowFIT
  ShowFIT : fitSearchMode에 따라
  ShowFIT : 조합 카드 / 항공 카드 / 숙소 카드
  ShowFIT : [비교하기] [추천 다시받기]
  ShowFIT --> FITDetail : 카드 클릭
  ShowFIT --> FITComparison : 비교하기
  ShowFIT --> ShowFIT : 추천 다시받기
  FITDetail : FITPackageDetail / FlightDetail / HotelDetail
  FITComparison : FITComparison / FlightComparison / HotelComparison
  FITDetail --> ShowFIT : 닫기
  FITComparison --> FITDetail : 항목 선택
}

packages --> booking : [예약하기] 클릭

fit_packages --> room_type : [예약하기] (조합 or 숙소만)
fit_packages --> booking : [예약하기] (항공만)

state room_type <<booking>> {
  [*] --> RoomTypeSelector
  RoomTypeSelector : 룸타입 선택 바텀시트
  RoomTypeSelector : 호텔별 룸타입 + 추가 요금
  RoomTypeSelector --> booking : 룸타입 선택 완료
}

state booking <<booking>> {
  [*] --> BookingForm
  BookingForm : 예약자 정보 입력
  BookingForm : 이름, 연락처, 여행자 수
  BookingForm --> payment : 제출
}

booking --> payment : 예약 정보 확인 메시지

state payment <<payment>> {
  [*] --> PaymentModal
  PaymentModal : 결제 모달
  PaymentModal : 결제 방법 선택
  PaymentModal --> confirmed : 결제 완료
  PaymentModal --> booking : 취소
}

payment --> confirmed : 결제 성공

state confirmed {
  [*] --> BookingConfirmation
  BookingConfirmation : 예약 번호 (HAI + timestamp)
  BookingConfirmation : 상품명, 여행자 수, 결제 금액
  BookingConfirmation : FIT 시 완료 제안 메시지
  BookingConfirmation --> initial : [확인] 클릭
}

confirmed --> initial : 초기화 후 채팅으로 복귀

initial --> main : 헤더 [뒤로가기] 클릭

note right of main
  step = "main"
  MainPage 전용 화면
end note

note right of initial
  step = "initial"
  채팅 + 선호도 전까지
end note

note right of preference
  step = "preference"
  showPreferenceInput = true
end note

note right of packages
  step = "packages"
  상세/비교는 step 유지
  (showDetail / showComparison)
end note

note right of fit_packages
  step = "fit-packages"
  fitSearchMode:
  combo | flight | hotel
end note

note right of room_type
  step 유지 (fit-packages 등)
  showRoomTypeSelector = true
  조합/숙소만 예약 시만 진입
end note

note right of booking
  step = "booking"
  showBookingForm = true
end note

note right of payment
  step = "payment"
  showPayment = true
end note

note right of confirmed
  step = "confirmed"
  showConfirmation = true
end note

note bottom of fit_packages
  fit-activities / fit-summary
  (액티비티 선택) 경로는
  현재 선택적 확장
end note

note bottom of packages
  PackageDetail UI: H-AI 요약 10px, 30% 자유시간 보장 줄바꿈 방지
  (2026-03-18 반영)
end note

@enduml
